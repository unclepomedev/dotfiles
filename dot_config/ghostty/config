# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# Theme
theme = "tokyonight"

# Window
window-padding-x = 10
window-padding-y = 10
background-opacity = 0.95
background-blur-radius = 20

# macOS specific
macos-titlebar-style = transparent
macos-option-as-alt = true

# Behavior
copy-on-select = true
confirm-close-surface = false
