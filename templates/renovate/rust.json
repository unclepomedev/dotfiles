{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Rust dependencies",
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "rust dependencies",
      "automerge": false
    },
    {
      "description": "tokio monorepo",
      "matchPackageNames": [
        "/^tokio/"
      ],
      "groupName": "tokio monorepo"
    }
  ],
  "schedule": [
    "* 0-5 * * 1"
  ],
  "labels": [
    "renovate"
  ],
  "assignees": [
    "unclepomedev"
  ]
}
