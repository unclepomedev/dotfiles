{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions",
      "automerge": false,
      "automergeType": "pr",
      "pinDigests": true
    },
  ],
  "schedule": [
    "* 0-5 * * 1"
  ],
  "labels": [
    "renovate"
  ],
  "assignees": [
    "unclepomedev"
  ]
}
